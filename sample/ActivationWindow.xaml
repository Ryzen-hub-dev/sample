<Window x:Class="sample.ActivationWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:sample"
        mc:Ignorable="d"
        Title="Activation" 
        WindowStartupLocation="CenterScreen" 
        WindowStyle="None" 
        ResizeMode="NoResize" 
        Topmost="True" 
        Height="500" 
        Width="600"
        Background="Transparent"
        AllowsTransparency="True">

    <!-- 窗口资源 - 定义按钮样式 -->
    <Window.Resources>
        <Style TargetType="{x:Type Button}">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="border" 
                                CornerRadius="4" 
                                Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#3A3838"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <!-- 主窗口边框，带阴影效果 -->
    <Border Background="#252525" CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect ShadowDepth="5" BlurRadius="20" Opacity="0.5"/>
        </Border.Effect>

        <Grid>
            <!-- 标题栏 -->
            <Border Height="50" Background="#1E1E1E" CornerRadius="10,10,0,0" Margin="2,2,-2,448">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 标题文字 -->
                    <Label Content="Sample CDK ACTIVATION" 
                           Foreground="White" 
                           FontSize="18" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center" 
                           Margin="15,0"
                           MouseDown="Panel_MouseDown"/>

                    <!-- 最小化按钮 -->
                    <Button x:Name="Minimize" 
                            Grid.Column="1" 
                            Content="➖" 
                            Background="Transparent" 
                            Width="50" 
                            Height="50"
                            Click="Minimize_Click"
                            ToolTip="Minimize"/>

                    <!-- 关闭按钮 -->
                    <Button x:Name="Close" 
                            Grid.Column="2" 
                            Content="❌" 
                            Background="Transparent" 
                            Width="50" 
                            Height="50"
                            Click="Close_Click"
                            ToolTip="Close"/>
                </Grid>
            </Border>

            <!-- 主体内容 -->
            <Grid VerticalAlignment="Center" Margin="40,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="30"/>
                </Grid.RowDefinitions>

                <!-- CDK输入区域 -->
                <StackPanel Grid.Row="0" Orientation="Vertical">
                    <Label Content="CDK KEY" 
                           Foreground="White" 
                           FontSize="16" 
                           Margin="0,0,0,5"/>

                    <Border CornerRadius="4" 
                            Height="45" 
                            Background="#333333">
                        <TextBox x:Name="CDKTextBox" 
                                 Text="" 
                                 Foreground="White" 
                                 Background="Transparent" 
                                 BorderThickness="0" 
                                 FontSize="16" 
                                 Padding="10"
                                 FontFamily="Consolas"/>
                    </Border>
                </StackPanel>

                <!-- 激活按钮 -->
                <Button x:Name="ActivateButton" 
                        Grid.Row="2"
                        Content="ACTIVATE ACCOUNT" 
                        Background="#3C8DBC" 
                        Width="300" 
                        Height="50" 
                        FontWeight="Bold"
                        Click="ActivateButton_Click"/>

                <!-- 状态信息 -->
                <TextBlock x:Name="StatusText" 
                           Grid.Row="3"
                           Foreground="#FF777777" 
                           TextAlignment="Center" 
                           FontSize="14" 
                           VerticalAlignment="Center"
                           Margin="0,10,0,0"/>
            </Grid>

            <!-- 底部版权信息 -->
            <TextBlock Text="© 2025 Product Name. All Rights Reserved" 
                       VerticalAlignment="Bottom" 
                       HorizontalAlignment="Center" 
                       Margin="0,0,0,15"
                       Foreground="#555555" 
                       FontSize="12"/>
        </Grid>
    </Border>
</Window>